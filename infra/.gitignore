# Ignore sensitive Terraform files
terraform.tfvars
*.tfvars.json
terraform.tfstate
terraform.tfstate.backup
.terraform/

# Ignore SSH keys
*.pem
*.key

# Ignore environment files
.env
.env.local

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore logs
*.log

# Keep the example template so developers know what to do
!terraform.tfvars.example
